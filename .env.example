# DeepSeek API Configuration
# Replace with your DeepSeek API Key (or OpenAI-compatible equivalent)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Fallback compatibility keys (e.g. if copying keys from BibiGPT)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Bilibili Session Cookie (Optional)
# SESSDATA cookie value from your browser cookies on bilibili.com.
# Required for fetching transcripts of restricted or high-definition videos.
BILIBILI_SESSION_TOKEN=
